#!/usr/bin/env bash
# pre-push hook - 推送前检查
# 检查: 待推送 commit 规范、关联 PR 标题/描述规范

set -eo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

HAS_ERROR=0
HAS_WARNING=0

COMMIT_SUBJECT_REGEX='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,80}$'
PR_PLACEHOLDER_PATTERNS=(
    '^[[:space:]]*-[[:space:]]*What changed\?[[:space:]]*$'
    '^[[:space:]]*-[[:space:]]*Why is this change needed\?[[:space:]]*$'
    '^[[:space:]]*-[[:space:]]*Main risk of this PR:[[:space:]]*$'
    '^[[:space:]]*-[[:space:]]*Rollback path:[[:space:]]*$'
)
PR_REQUIRED_HEADINGS=(
    "## Summary"
    "## Validation"
    "## Contract Check"
    "## Snapshot Check"
    "## Docs Check"
    "## External Tool Check"
    "## Plugin Contribution Check"
    "## Risks"
)

info()  { echo -e "${GREEN}[OK]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!!]${NC} $1"; HAS_WARNING=1; }
error() { echo -e "${RED}[XX]${NC} $1"; HAS_ERROR=1; }

is_all_zero_oid() {
    case "$1" in
        0000000000000000000000000000000000000000) return 0 ;;
        *) return 1 ;;
    esac
}

extract_repo_slug() {
    local remote_url="$1"

    case "$remote_url" in
        https://github.com/*)
            remote_url="${remote_url#https://github.com/}"
            remote_url="${remote_url%.git}"
            printf '%s\n' "$remote_url"
            return 0
            ;;
        git@github.com:*)
            remote_url="${remote_url#git@github.com:}"
            remote_url="${remote_url%.git}"
            printf '%s\n' "$remote_url"
            return 0
            ;;
    esac

    return 1
}

validate_commit_message() {
    local commit_sha="$1"
    local first_line commit_body

    first_line=$(git log -1 --format=%s "$commit_sha")
    commit_body=$(git log -1 --format=%B "$commit_sha")

    if ! printf '%s\n' "$first_line" | grep -qE "$COMMIT_SUBJECT_REGEX"; then
        error "commit $commit_sha 提交标题不符合规范: $first_line"
    fi

    if printf '%s\n' "$commit_body" | grep -qE '^Co-Authored-By:'; then
        error "commit $commit_sha 包含 Co-Authored-By trailer"
    fi

    if printf '%s\n' "$commit_body" | grep -qiE 'Generated with.*Code'; then
        error "commit $commit_sha 包含 AI 生成标识"
    fi
}

validate_pr_body() {
    local pr_body="$1"
    local heading placeholder_pattern

    if [ -z "$pr_body" ]; then
        error "PR 描述为空，缺少模板内容"
        return
    fi

    for heading in "${PR_REQUIRED_HEADINGS[@]}"; do
        if ! printf '%s\n' "$pr_body" | grep -Fq -- "$heading"; then
            error "PR 描述缺少必需段落: $heading"
        fi
    done

    for placeholder_pattern in "${PR_PLACEHOLDER_PATTERNS[@]}"; do
        if printf '%s\n' "$pr_body" | grep -Eq -- "$placeholder_pattern"; then
            error "PR 描述仍保留未填写占位内容: $placeholder_pattern"
        fi
    done
}

validate_associated_pr() {
    local remote_name="$1"
    local remote_url="$2"
    local current_branch repo_slug pr_number pr_title pr_body

    if ! command -v gh >/dev/null 2>&1; then
        warn "未检测到 gh，跳过本地 PR 校验"
        return
    fi

    current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
    if [ -z "$current_branch" ]; then
        warn "当前不是分支 HEAD，跳过本地 PR 校验"
        return
    fi

    if ! repo_slug=$(extract_repo_slug "$remote_url"); then
        warn "无法从远端地址解析 GitHub 仓库，跳过本地 PR 校验: $remote_url"
        return
    fi

    pr_number=$(gh pr list \
        --repo "$repo_slug" \
        --head "$current_branch" \
        --state open \
        --json number \
        --jq '.[0].number' 2>/dev/null || true)

    if [ -z "$pr_number" ] || [ "$pr_number" = "null" ]; then
        warn "分支 $current_branch 在 $remote_name 上没有打开中的 PR，跳过本地 PR 校验"
        return
    fi

    pr_title=$(gh pr view "$pr_number" --repo "$repo_slug" --json title --jq '.title' 2>/dev/null || true)
    pr_body=$(gh pr view "$pr_number" --repo "$repo_slug" --json body --jq '.body' 2>/dev/null || true)

    if [ -z "$pr_title" ]; then
        error "无法读取 PR #$pr_number 标题"
        return
    fi

    if ! printf '%s\n' "$pr_title" | grep -qE "$COMMIT_SUBJECT_REGEX"; then
        error "PR #$pr_number 标题不符合规范: $pr_title"
    fi

    validate_pr_body "$pr_body"
}

REMOTE_NAME=$1
REMOTE_URL=$2
SEEN_COMMIT=0

while read -r local_ref local_oid remote_ref remote_oid; do
    if [ -z "$local_ref" ] || [ -z "$local_oid" ]; then
        continue
    fi

    local_ref=${local_ref%$'\r'}
    local_oid=${local_oid%$'\r'}
    remote_ref=${remote_ref%$'\r'}
    remote_oid=${remote_oid%$'\r'}

    if is_all_zero_oid "$local_oid"; then
        continue
    fi

    SEEN_COMMIT=1

    if is_all_zero_oid "$remote_oid"; then
        while read -r commit_sha; do
            [ -n "$commit_sha" ] && validate_commit_message "$commit_sha"
        done < <(git rev-list "$local_oid" --not --all)
    else
        while read -r commit_sha; do
            [ -n "$commit_sha" ] && validate_commit_message "$commit_sha"
        done < <(git rev-list "${remote_oid}..${local_oid}")
    fi
done

if [ "$SEEN_COMMIT" -gt 0 ]; then
    validate_associated_pr "$REMOTE_NAME" "$REMOTE_URL"
fi

echo ""
if [ "$HAS_ERROR" -gt 0 ]; then
    echo -e "${RED}推送检查失败，请修复上述问题${NC}"
    exit 1
elif [ "$HAS_WARNING" -gt 0 ]; then
    echo -e "${YELLOW}推送检查存在警告，请确认是否继续${NC}"
fi

info "推送检查通过"
exit 0
