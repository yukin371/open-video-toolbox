{
  "source": {
    "kind": "builtIn"
  },
  "template": {
    "id": "shorts-captioned",
    "displayName": "Shorts Captioned",
    "description": "Short-form cut with subtitle slot prepared for caption-driven publishing.",
    "category": "short-form",
    "version": "1.0.0",
    "outputContainer": "mp4",
    "defaultSubtitleMode": "sidecar",
    "parameterDefaults": {
      "hookStyle": "hard-cut",
      "captionStyle": "burn-later"
    },
    "recommendedSeedModes": [
      "manual",
      "transcript",
      "beats"
    ],
    "recommendedTranscriptSeedStrategies": [
      "grouped",
      "maxGap"
    ],
    "artifactSlots": [
      {
        "id": "subtitles",
        "kind": "subtitle",
        "description": "Optional subtitle file to attach or burn in later.",
        "required": false
      }
    ],
    "supportingSignals": [
      {
        "kind": "transcript",
        "reason": "Use transcript segments to line up caption-first hooks with spoken lines."
      },
      {
        "kind": "beats",
        "reason": "Use beat markers when the short needs rhythm-first pacing but should still keep caption outputs ready."
      },
      {
        "kind": "silence",
        "reason": "Use silence markers to catch long pauses before locking subtitle timing and clip boundaries."
      }
    ]
  },
  "examples": {
    "outputDirectory": null,
    "writtenFiles": null,
    "artifactsFileName": "artifacts.json",
    "artifacts": {
      "subtitles": "subtitles.srt"
    },
    "templateParamsFileName": "template-params.json",
    "templateParams": {
      "hookStyle": "hard-cut",
      "captionStyle": "burn-later"
    },
    "seedModes": [
      "manual",
      "transcript",
      "beats"
    ],
    "supportingSignals": [
      {
        "kind": "transcript",
        "reason": "Use transcript segments to line up caption-first hooks with spoken lines.",
        "outputPath": "transcript.json",
        "command": "ovt transcribe \u003Cinput\u003E --model \u003Cwhisper-model-path\u003E --output transcript.json",
        "consumption": "Pass --transcript transcript.json to init-plan and enable --seed-from-transcript when dialogue should drive the first clip layout. If edit.json already exists, attach it with ovt attach-plan-material --plan edit.json --transcript --path transcript.json --check-files before inspect-plan / validate-plan / render."
      },
      {
        "kind": "beats",
        "reason": "Use beat markers when the short needs rhythm-first pacing but should still keep caption outputs ready.",
        "outputPath": "beats.json",
        "command": "ovt beat-track \u003Cinput\u003E --output beats.json",
        "consumption": "Pass --beats beats.json to init-plan and enable --seed-from-beats when rhythm should shape the initial clip pacing. If edit.json already exists, attach it with ovt attach-plan-material --plan edit.json --beats --path beats.json --check-files before inspect-plan / validate-plan / render."
      },
      {
        "kind": "silence",
        "reason": "Use silence markers to catch long pauses before locking subtitle timing and clip boundaries.",
        "outputPath": "silence.json",
        "command": "ovt detect-silence \u003Cinput\u003E --output silence.json",
        "consumption": "Review silence.json before hand-tuning edit.json clip boundaries or transcript seed settings so long pauses do not survive into the first cut."
      }
    ],
    "commandFiles": [
      "commands.json",
      "commands.ps1",
      "commands.cmd",
      "commands.sh"
    ],
    "commands": [
      "ovt init-plan \u003Cinput\u003E --template shorts-captioned --output edit.json --render-output final.mp4",
      "ovt init-plan \u003Cinput\u003E --template shorts-captioned --output edit.json --render-output final.mp4 --artifacts artifacts.json",
      "ovt init-plan \u003Cinput\u003E --template shorts-captioned --output edit.json --render-output final.mp4 --template-params template-params.json"
    ],
